# Option 1: Local LLM (Ollama, LM Studio - runs on your machine, private)
# LOCAL_LLM_URL=http://localhost:11434
# LOCAL_LLM_MODEL=llama3.2

# Option 2: Google Gemini (FREE) - https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Option 3: Groq (FREE, high limits) - https://console.groq.com/keys
# GROQ_API_KEY=your-groq-api-key

# Option 4: OpenAI (paid)
# OPENAI_API_KEY=sk-your-api-key-here

# RAG (Retrieval-Augmented Generation) — grounds answers in data/rag_knowledge.json
# RAG_ENABLED=true
# RAG_TOP_K=3

# Emotion & mood (see requirements-ml.txt for torch + transformers)
# USE_TRANSFORMERS_EMOTION=true
# USE_FACE_EMOTION=true
# EMOTION_TEXT_MODEL=j-hartmann/emotion-english-distilroberta-base
# EMOTION_FACE_MODEL=trpakov/vit-face-expression

# Mood analytics: local JSON file data/mood_events.json (or DynamoDB—see ETHICS_AND_PRIVACY.md)
# MOOD_TRACKING_ENABLED=true
# MOOD_ANONYMIZE=false
# MOOD_HASH_SALT=change-me
# MOOD_BACKEND=json
# MOOD_DYNAMODB_TABLE=mental-health-mood-events
# AWS_REGION=eu-west-2

# Dashboard API
# ANALYTICS_API_ENABLED=true

# Max image upload size (MB) for face emotion
# MAX_UPLOAD_MB=8
