# Option 1: Local LLM (Ollama, LM Studio - runs on your machine, private)
# LOCAL_LLM_URL=http://localhost:11434
# LOCAL_LLM_MODEL=llama3.2

# Option 2: Google Gemini (FREE) - https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Option 3: Groq (FREE, high limits) - https://console.groq.com/keys
# GROQ_API_KEY=your-groq-api-key

# Option 4: OpenAI (paid)
# OPENAI_API_KEY=sk-your-api-key-here

# RAG (Retrieval-Augmented Generation) — grounds answers in data/rag_knowledge.json
# RAG_ENABLED=true
# RAG_TOP_K=3
